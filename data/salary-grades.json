  "allowances": {
    "note": "These allowances are provided ON TOP of basic salary for all permanent government employees.",
    "items": [
      {
        "name": "Personnel Economic Relief Allowance (PERA)",
        "amount": 2000,
        "frequency": "monthly",
        "description": "Standard monthly allowance for all government employees."
      },
      {
        "name": "Representation and Transportation Allowance (RATA)",
        "applicableTo": "SG 24 and above (and certain positions below)",
        "frequency": "monthly",
        "description": "For officials with official representation and transportation duties."
      },
      {
        "name": "Clothing Allowance",
        "amount": 6000,
        "frequency": "annual",
        "description": "Annual allowance for uniform and clothing. Usually released in first semester."
      },
      {
        "name": "Mid-Year Bonus",
        "amount": "1 month basic salary",
        "frequency": "annual",
        "releaseMonth": "May",
        "description": "Released in May to eligible employees with at least 4 months of service."
      },
      {
        "name": "Year-End Bonus",
        "amount": "1 month basic salary",
        "frequency": "annual",
        "releaseMonth": "November",
        "description": "Released in November. Requires complete service for the year."
      },
      {
        "name": "13th Month Pay",
        "amount": "1 month basic salary",
        "frequency": "annual",
        "releaseMonth": "December",
        "description": "Constitutionally mandated. All permanent employees receive this."
      },
      {
        "name": "Productivity Enhancement Incentive (PEI)",
        "amount": 5000,
        "frequency": "annual",
        "releaseMonth": "December",
        "description": "Performance-based incentive released in December."
      },
      {
        "name": "Cash Gift",
        "amount": 5000,
        "frequency": "annual",
        "releaseMonth": "November",
        "description": "Annual cash gift released alongside Year-End Bonus."
      },
      {
        "name": "Loyalty Cash Award",
        "frequency": "every 5 years",
        "description": "Awarded every 5 years of continuous government service. Amount varies."
      },
      {
        "name": "Night Shift Differential",
        "applicableTo": "Employees working 10:00 PM – 6:00 AM",
        "description": "Additional 10-20% of hourly rate for nighttime work. Relevant for nurses, security, etc."
      }
    ]
  },

  "deductions": {
    "note": "Mandatory monthly deductions from basic salary for all permanent employees.",
    "items": [
      {
        "name": "GSIS Premium",
        "rate": 0.09,
        "basis": "basic salary",
        "description": "Government Service Insurance System. Covers life insurance, retirement, and loans."
      },
      {
        "name": "Pag-IBIG (HDMF)",
        "amount": 100,
        "description": "Fixed ₱100/month for employees. Government counterpart is ₱100. For housing fund."
      },
      {
        "name": "PhilHealth",
        "rate": 0.025,
        "basis": "basic salary",
        "cap": 2500,
        "description": "National health insurance. 2.5% of basic salary (employee share = half of total 5%)."
      },
      {
        "name": "Withholding Tax",
        "basis": "taxable income",
        "description": "Based on BIR graduated tax table. Many SG 1-10 employees pay zero tax."
      }
    ]
  },

  "stepIncrements": {
    "description": "Employees advance one step every 3 years of satisfactory service.",
